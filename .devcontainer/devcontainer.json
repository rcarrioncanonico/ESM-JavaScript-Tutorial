{
  "name": "Cognitive ESM Lab (JS + Phaser)",
  "image": "denoland/deno:latest",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-toolsai.jupyter",
        "denoland.vscode-deno"
      ],
      "settings": {
        "deno.enable": true,
        "deno.lint": true,
        "[python]": {
          "defaultInterpreterPath": "${workspaceFolder}/.deno/bin/deno",
          "formatting.provider": "none"
        }
      }
    }
  },
  "postCreateCommand": "deno jupyter --install && deno run --allow-net --allow-read https://deno.land/std@0.190.0/http/file_server.ts --port 8080 &"
  
}